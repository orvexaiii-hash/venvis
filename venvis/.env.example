ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
PORT=3000
SESSION_NAME=agus

# Búsqueda web (Serper — 2500 búsquedas/mes gratis)
SERPER_API_KEY=YOUR_SERPER_KEY

# Búsqueda web alternativa (Google Custom Search)
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
GOOGLE_SEARCH_ENGINE_ID=YOUR_SEARCH_ENGINE_ID

# Google Calendar (OAuth2)
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET
GOOGLE_REFRESH_TOKEN=YOUR_REFRESH_TOKEN

# Tuya domótica
TUYA_CLIENT_ID=YOUR_TUYA_CLIENT_ID
TUYA_CLIENT_SECRET=YOUR_TUYA_CLIENT_SECRET
TUYA_DEVICE_ID_LAMP=YOUR_LAMP_DEVICE_ID
TUYA_DEVICE_ID_IR=YOUR_IR_DEVICE_ID
TUYA_DEVICE_ID_AC=YOUR_AC_DEVICE_ID

# Presencia Ambiental
PHONE_IP=           # IP local del celular en la red WiFi de casa (ej: 192.168.1.100)
WEATHER_LOCATION=   # Ciudad para el clima (ej: Buenos Aires). Vacío = autodetectar por IP
